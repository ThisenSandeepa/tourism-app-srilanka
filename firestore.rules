rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - each user can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Tours collection
    match /tours/{tourId} {
      // Drivers can read/write tours assigned to them
      allow read: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        resource.data.guestId == request.auth.uid
      );
      allow write: if request.auth != null &&
        resource.data.driverId == request.auth.uid;
    }

    // Earnings - only accessible by the driver who owns them
    match /earnings/{earningId} {
      allow read, write: if request.auth != null &&
        resource.data.driverId == request.auth.uid;
    }

    // Tips & Reviews - guests can create, drivers can read their own
    match /tips/{tipId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        resource.data.driverId == request.auth.uid ||
        resource.data.guestId == request.auth.uid
      );
    }

    // Knowledge Vault - read-only for all authenticated users
    match /knowledge/{docId} {
      allow read: if request.auth != null;
    }

    // Vehicle maintenance - only accessible by the driver
    match /vehicles/{vehicleId} {
      allow read, write: if request.auth != null &&
        resource.data.driverId == request.auth.uid;
    }
  }
}
